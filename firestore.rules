rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for the reviews collection
    match /reviews/{review} {
      // Anyone can read reviews to see them on the site
      allow read: if true; 
      
      // Allow creating a review if it has valid data
      allow create: if request.resource.data.name != "" 
                    && request.resource.data.rating >= 1 
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment.size() > 0;
      
      // Disallow updates and deletes from the client for security
      allow update, delete: if false;
    }
    
    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}